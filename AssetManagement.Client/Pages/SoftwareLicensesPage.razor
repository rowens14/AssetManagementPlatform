@using AssetManagement.Shared.Models.DTOs.Dashboard
@*
    FILE:    SoftwareLicensesPage.razor
    PROJECT: AssetManagement.Client / Pages
    PURPOSE: Software license inventory and management (Screen 7 of the UI mockup).
             Lists all software licenses across both office sites with vendor name,
             license type, a utilization progress bar (seats used vs. total), expiry date,
             and status badge. Supports search by product name, vendor or type, and
             filtering by site and status. Highlights licenses expiring within 30 days.
             Raises EventCallback<LicenseDto?> to App.razor to open the add/edit modal.
             Maps to Requirements FR 01, FR 02, FR 05, FR 10.
*@

@inject ClientApplicationState State


<div class="page-hdr">
    <div class="page-hdr-left">
        <h2>Software Inventory &amp; Licenses</h2>
       
    </div>
    @if (State.CanEdit)
    {
        <button class="btn btn-primary" @onclick="() => OnEdit.InvokeAsync(null)">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            Add Software License
        </button>
    }
</div>

<div class="filter-bar">
    <div class="search-box" style="flex:1">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Search by name, manufacturer, or ID..." />
    </div>
    <div class="filter-label">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
        </svg>
    </div>
    <select class="filter-select" @bind="siteFilter">
        <option value="0">All Sites</option>
        @foreach (var s in State.Sites) { <option value="@s.Id">@s.Name</option> }
    </select>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Software / Vendor</th>
                    <th>License Type</th>
                    <th>Utilization</th>
                    <th>Site</th>
                    <th>Exp. Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{var rows = Filtered.ToList();}
                @if (!rows.Any())
                {
                    <tr><td colspan="7"><div class="empty-state"><div class="empty-text">No licenses found</div></div></td></tr>
                }
                @foreach (var l in rows)
                {
                    var pct = l.Total > 0 ? 75 : 0; // placeholder until seat tracking added
                    var fillClass = pct >= 90 ? "crit" : pct >= 75 ? "warn" : "";
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px">
                                <div class="sw-icon">
                                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                                        <line x1="8" y1="21" x2="16" y2="21"/>
                                        <line x1="12" y1="17" x2="12" y2="21"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="sw-name">@l.Product</div>
                                    <div class="sw-vendor">@l.Vendor @(string.IsNullOrEmpty(l.Vendor) ? "" : "·") @l.Type</div>
                                </div>
                            </div>
                        </td>
                        <td>@l.Type</td>
                        <td>
                            <div class="util-wrap">
                                <span class="util-seats">@l.Total seats</span>
                                <div class="util-track">
                                    <div class="util-fill @fillClass" style="width:@(pct)%"></div>
                                </div>
                                <span class="util-pct">@(pct)%</span>
                            </div>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:5px;">
                                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10"/>
                                </svg>
                                @(State.GetSite(l.SiteId)?.Name ?? "—")
                            </div>
                        </td>
                        <td class="td-mono" style="@(l.IsExpiringSoon ? "color:var(--amber);" : "")">
                            @(l.Expiry.HasValue ? l.Expiry.Value.ToString("yyyy-MM-dd") : "—")
                            @if (l.IsExpiringSoon) { <span style="margin-left:4px;">⚠</span> }
                        </td>
                        <td><AssetStatusBadge Status="@l.Status" /></td>
                        <td>
                            @if (State.CanEdit)
                            {
                                <button class="action-link" @onclick="() => OnEdit.InvokeAsync(l)" style="margin-right:8px;">Edit</button>
                                <button class="action-link" style="color:var(--red);" @onclick="() => DeleteLicense(l.Id)">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


@code {
    [Parameter] public EventCallback<LicenseDto?> OnEdit { get; set; }

    string searchQuery = "";
    int siteFilter = 0;

    IEnumerable<LicenseDto> Filtered => State.Licenses.Where(l =>
    {
        var q = searchQuery.ToLower();
        if (!string.IsNullOrEmpty(q) && !new[] { l.Product, l.Vendor, l.Type }
            .Any(v => v?.ToLower().Contains(q) == true)) return false;
        if (siteFilter != 0 && l.SiteId != siteFilter) return false;
        return true;
    });

    async Task DeleteLicense(int id) => await State.DeleteLicenseAsync(id);
}
